{
  "name": "lantern-qvac",
  "version": "1.0.0",
  "private": true,
  "description": "Lantern — a private, fully on-device AI sight & voice assistant for blind and low-vision people, built on the QVAC SDK. No cloud, ever.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.17",
    "npm": ">=10.9"
  },
  "bin": {
    "lantern": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js web",
    "web": "node src/index.js web",
    "cli": "node src/index.js cli",
    "hub": "node src/index.js hub",
    "demo": "node scripts/demo.js",
    "doctor": "node scripts/doctor.js",
    "bench": "node scripts/bench.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "optionalDependencies": {
    "@qvac/sdk": "^0.13.2"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "vitest": "^4.1.9"
  }
}
