# ───────────────────────────────────────────────────────────────────────────
# Lantern environment configuration
# Everything here is OPTIONAL — sane defaults live in config/lantern.config.json.
# Copy this file to `.env` and edit as needed:  cp .env.example .env
# ───────────────────────────────────────────────────────────────────────────

# Engine selection:
#   qvac → real, 100% on-device inference via @qvac/sdk (requires the SDK + models)
#   mock → offline deterministic simulation for development & tests (NO real AI,
#          clearly labelled as such in every output and audit-log line)
LANTERN_ENGINE=qvac

# Compute device for inference: "gpu" or "cpu"
LANTERN_DEVICE=gpu

# Web server bind address (keep it loopback — Lantern is a personal, local app)
LANTERN_HOST=127.0.0.1
LANTERN_PORT=4173

# Path to a custom config file (defaults to config/lantern.config.json)
LANTERN_CONFIG=

# ── P2P delegated inference (optional, showcases QVAC's signature capability) ──
# On your SECOND machine (the "Lantern Hub"), run:  npm run hub
# It prints a public key. Paste that key below on the FIELD device and set
# LANTERN_DELEGATE_VISION=true to offload the heavy vision model to the Hub,
# with automatic fallback to local inference if the Hub is unreachable.
LANTERN_DELEGATE_VISION=false
LANTERN_PROVIDER_PUBLIC_KEY=

# Deterministic identity seed for the Hub so it keeps a stable public key across
# restarts (optional). Any string; keep it private, like a password.
QVAC_HYPERSWARM_SEED=

# Point this at a JSON file to surface the QVAC SDK's own internal logs (optional).
# QVAC_CONFIG_PATH=
